# WeatherKit (Apple) — required for live weather
WEATHERKIT_TEAM_ID=
WEATHERKIT_SERVICE_ID=
WEATHERKIT_KEY_ID=
WEATHERKIT_PRIVATE_KEY=

# RevenueCat — use one key for both or set per platform
REVENUECAT_API_KEY=your_public_api_key
# REVENUECAT_API_KEY_IOS=
# REVENUECAT_API_KEY_ANDROID=

# Google Maps (Android) — required for map screen on Android dev/production builds
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
