# WeatherKit (Apple) — required for live weather
WEATHERKIT_TEAM_ID=
WEATHERKIT_SERVICE_ID=
WEATHERKIT_KEY_ID=
WEATHERKIT_PRIVATE_KEY=
# Optional backend proxy endpoint (recommended for production spike resilience)
WEATHER_PROXY_BASE_URL=
# Optional explicit airports proxy URL (defaults to WEATHER_PROXY_BASE_URL with /airports path)
AIRPORTS_PROXY_BASE_URL=
# If false, never call Apple directly from devices
WEATHER_DIRECT_ENABLED=true
# Emergency kill switch for live weather
WEATHER_DISABLED=false
# Retry count for transient upstream failures (502/503/504/network/timeout)
WEATHER_RETRY_MAX=3
# Per request timeout in milliseconds
WEATHER_REQUEST_TIMEOUT_MS=15000

# RevenueCat — use one key for both or set per platform
REVENUECAT_API_KEY=your_public_api_key
# REVENUECAT_API_KEY_IOS=
# REVENUECAT_API_KEY_ANDROID=

# Google Maps (Android) — required for map screen on Android dev/production builds.
# Used by app.config.js (Expo prebuild) and android/app/build.gradle (manifest at build time).
# Do not commit real keys; copy this file to .env and fill in.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
# Optional alias (same value); Gradle reads this if the EXPO_PUBLIC_ var is unset:
# GOOGLE_MAPS_ANDROID_API_KEY=
